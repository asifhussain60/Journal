# Babu Journal — environment template.
#
# PRIMARY METHOD: Do NOT create a real .env with the API key.
# Store the Anthropic key in macOS Keychain instead (see docs/proxy-setup.md).
# Keychain is the default; this file only exists for rare fallback scenarios
# (CI, containers, non-macOS development).
#
# If you must use a .env (not recommended), copy this file to server/.env
# and fill it in. .env is gitignored.

# --- Anthropic API ---
# Optional fallback key — only used if Keychain lookup fails.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Server ---
# PORT=3001

# --- CORS allowlist (comma-separated) ---
# ALLOWED_ORIGINS=http://localhost:3000,https://journal.kashkole.com,https://journal-dev.kashkole.com

# --- Monthly Anthropic spend cap in dollars ---
# MONTHLY_CAP=50

# --- Cloudflare Access (set after creating the Access application) ---
# Team domain from your Access sign-in URL
# CF_ACCESS_TEAM_DOMAIN=asifhussain.cloudflareaccess.com
# Application AUD tag from the Access application's Overview tab (long hex)
# CF_ACCESS_AUD=

# --- Shadow-write (Phase 9 Stage B dual-write) ---
# SHADOW_WRITE_ENABLED=true
